# ===========================
# KRISHI SAKHI - .gitignore
# Monorepo: frontend/ + backend/ + hardware/
# ===========================

# ---- FRONTEND (Next.js) ----
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.pnp
frontend/.pnp.js
frontend/next-env.d.ts
frontend/*.tsbuildinfo
frontend/.vercel
frontend/coverage/

# ---- BACKEND (Python FastAPI) ----
backend/__pycache__/
backend/**/__pycache__/
backend/.venv/
backend/venv/
backend/env/
backend/*.egg-info/
backend/dist/
backend/build/
backend/.pytest_cache/
backend/.mypy_cache/
backend/app/models/*.pkl
backend/app/models/market_prophet/*.pkl
# Keep training scripts, ignore trained model binaries

# ---- HARDWARE (Raspberry Pi) ----
hardware/__pycache__/
hardware/*.db
# Local SQLite buffer files on Pi

# ---- ENVIRONMENT FILES ----
.env
.env.local
.env*.local
.env.development.local
.env.test.local
.env.production.local
frontend/.env
frontend/.env.local
frontend/.env*.local
backend/.env
backend/.env.local

# ---- GENERAL ----
# Dependencies
node_modules/

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Debug / Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs/
*.log

# Misc
*.pem

# Docker
docker-compose.override.yml
.dockerignore

# Supabase
.supabase/

# Data files (large CSVs - download via script, don't commit)
# backend/data/mandi_prices/*.csv
# Uncomment above if CSV files are too large for git
